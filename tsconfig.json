{
	"compilerOptions": {
		"rewriteRelativeImportExtensions": true,
		"allowJs": true,
		"checkJs": true,
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true,
		"skipLibCheck": true,
		"sourceMap": true,
		"strict": true,
		"module": "NodeNext",
		"moduleResolution": "NodeNext"
	},
	"exclude": [
		"./src/lib/test-artifacts/",
		"./src/lib/vitest-examples/"
	],
	"extends": "./.svelte-kit/tsconfig.json"
}
